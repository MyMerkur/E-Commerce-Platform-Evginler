extends ../layout/main_layout.pug

block content
    .container.mt-5.home
        h5 Sipariş İşlemleri
        .row 
            
            .col-12
                .indexOrdersInfo
                    .incomingOrdersContainer
                        a(href="/incomingOrders") 
                            h5.text-center Gelen Siparişler        
                        div(role='progressBar'  aria-valuemin='0' aria-valuemax='100' style=`--value: ${incomingOrders.length}`)
                        .orderInfo
                            ul 
                                li Gelen siparişleri kontrol edin.
                                li Kargo bilgilerini girin.
                                li Siparişi onaylayıp kargolayın.
                       

                    .deliveredOrdersContainer
                        a(href="/deliveredOrders") 
                            h5.text-center Teslim Edilmiş Siparişler     
                        div(role='progressBar'  aria-valuemin='0' aria-valuemax='100' style=`--value: ${deliveredOrders.length}`)
                        .orderInfo
                            ul 
                                li Teslim edilen siparişleri görüntüleyin.
                                li Teslim edilen siparişleri onaylayın
                                

                    .returnedOrdersContainer
                        a(href="/returnedOrders") 
                            h5.text-center İade Talepleri
                        div(role='progressBar'  aria-valuemin='0' aria-valuemax='100' style=`--value: ${returnedOrders.length}`)
                        .orderInfo
                            ul 
                                li İade talep edilen ürünleri görüntüleyin.
                              

        h5.mt-5 Finansal Durum
        .container.financial

            .row
                .col-12 
                    
                    table.table
                        thead
                            tr
                                th Toplam Sipariş Fiyatı
                                th İade Edilen Ürünlerin Fiyatı
                                th Güncel Kazanç
                        tbody
                            tr
                                td #{totalOrdersPrice}₺
                                td #{totalReturnedPrice}₺
                                td #{netEarnings}₺


            .row.mt-5
                .col-12 
                    .progress-group.mb-3
                        span Toplam Sipariş Fiyatı: #{totalOrdersPrice}₺
                        .progress(role='progressbar' aria-valuenow=totalOrdersPercent aria-valuemin='0' aria-valuemax='100')
                            .progress-bar.bg-primary(style=`width: ${totalOrdersPercent}%`)
                    .progress-group.mb-3
                        span İade Edilen Ürünlerin Fiyatı: #{totalReturnedPrice}₺
                        .progress(role='progressbar' aria-valuenow=returnedOrdersPercent aria-valuemin='0' aria-valuemax='100')
                            .progress-bar.bg-danger(style=`width: ${returnedOrdersPercent}%`)
                    .progress-group.mb-3
                        span Güncel Kazanç: #{netEarnings}₺
                        .progress(role='progressbar' aria-valuenow=netEarningsPercent aria-valuemin='0' aria-valuemax='100')
                            .progress-bar.bg-success(style=`width: ${netEarningsPercent}%`)
            
        
        .row.mt-5
            .row
                
                    h5.mb-4 Son Eklenen Ürünler
                    .indexProduct.d-flex
                        each product in products
                            .col-4
                                div.card(style='width: 18rem;')
                                    img.card-img-top(src=`${product.imageUrl[0]}` alt='...' style='height:20rem')
                                    .card-body
                                        p.card-text #{product.price}
                                        p #{product.name}
        
        
        
        
    

                    
           
                

                                