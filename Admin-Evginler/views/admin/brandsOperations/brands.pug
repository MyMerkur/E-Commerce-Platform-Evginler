extends ../../layout/main_layout.pug

block content 
    .container.mt-5.p-5

        if action !== 'undefined' && action === 'create'
            .alert.alert-success 
                | Yeni Marka Oluşturuldu
        if action !== 'undefined' && action === 'delete'
            .alert.alert-danger 
                | Marka Silindi
        if action !== 'undefined' && action === 'edit'
            .alert.alert-success 
                | Marka Yeniden Düzenlendi

        if brands.length > 0 
            table.table.table-bordered 
                thead   
                    tr  
                        th Marka İsmi 
                        th(style="width:133px;")

                tbody 
                    each brand in brands 
                        tr 
                            td #{brand.name}
                            td.d-flex
                                a.btn.btn-primary.btn-sm.mr-2(href=`/editBrand/${brand._id}`) Düzenle 

                                form(action="/deleteBrand", method="POST")
                                    input(type="hidden" name="_csrf" value=`${csrfToken}`)
                                    input(type="hidden" name="brandid" value=`${brand._id}`)
                                    button(type='submit').btn.btn-danger.btn-sm Sil  
    