extends ../../layout/main_layout.pug
block content
    .container.mt-5.p-5

        form(action="/addBrand", method="POST") 
            input(type="hidden" name="_csrf" value=`${csrfToken}`)
            .form-group.row 
                label(for='name').col-sm-2.col-form-label Marka Adı:
                .col-sm-10 
                    input.form-control#name(type="text" name='name')
            .form-group.row 
                    label(for="imageUrl").col-sm-2.col-form-label Marka Görseli 
                    .col-sm-10 
                        input.form-control-file#imageUrl1(type="text" name="imageUrl" placeholder="Görsel URL'yi girin")

            .form-group.row 
            .col-sm-10.offset-sm-2 
                    input(type="submit" value='Kaydet').btn.btn-primary