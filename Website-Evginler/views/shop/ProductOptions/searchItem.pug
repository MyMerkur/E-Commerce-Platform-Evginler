extends ../../layout/main-layout.pug
block content
    .container.mt-5
        h1 Arama Sonuçları

        if products.length
            .row
                each product in products
                    .col-4
                        .card(style="width: 18rem;")
                            if Array.isArray(product.imageUrl) && product.imageUrl.length > 0
                                img.card-img-top(src=product.imageUrl[0], alt="...")
                            else if product.imageUrl && !Array.isArray(product.imageUrl)
                                img.card-img-top(src=product.imageUrl, alt="...")
                            else
                                p Üzgünüz, ürün bulunamadı.
                            .card-body
                                h5.card-title #{product.name}
                                p.card-text #{product.description}
                                a.btn.btn-primary(href=`/productDetail/${product._id}`) Ürün Detay
        else
            p Hiçbir ürün bulunamadı.
