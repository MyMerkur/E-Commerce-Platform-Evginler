extends ../layout/main-layout.pug

block content 
    .container.mt-5 
        .container.categoriesContainer
            .row
                .col-lg-12
                    ul.category
                        each category in categories  
                            li.dropdown
                                a(href="#") #{category.name}
                                ul.dropdown-menu 
                                    li
                                        each subcategory in category.subcategories
                                            a(href=`/products/subcategory/${subcategory}`) #{subcategory}

        .container
            .row.searchBarContainer
                .col-sm-12.col-lg-12
                    form(action="/search", method="GET" style="display: flex; justify-content: center;").m-5
                            input.searchBar(type="text", name="q", placeholder="Aradığınız ürün, marka, kategori yazınız...")
                            button.btn-secondary(type="submit")
                                i.fa-solid.fa-magnifying-glass
        .container 
            .row 
                .col-12 
                        ul.brands.m-5
                            each brand in brands 
                                li
                                    a(href=`/products/${brand._id}`) 
                                        img(src=`${brand.imageUrl}`, alt="").brandsLogo
        
        
        #carouselExampleInterval.carousel.slide(data-bs-ride="carousel").mb-5
            .carousel-inner
                .carousel-item.active(data-bs-interval="5000")
                    img.d-block.w-100(src="/img/Beyaz Mavi Açık Yeşil Gradyan Barış Yanlısı Savaş Karşıtı Barış Afiş Yatay.png" alt="...")
                .carousel-item(data-bs-interval="2000")
                    img.d-block.w-100(src="https://img-tac-new.mncdn.com/Content/Images/Thumbs/0084985.webp" alt="...")
                .carousel-item
                    img.d-block.w-100(src="https://img-tac-new.mncdn.com/Content/Images/Thumbs/0085731.webp" alt="...")
            button.carousel-control-prev(type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="prev" ).d-flex.justify-content-start
                span.carousel-control-prev-icon(aria-hidden="true" style="color:black;")
                span.visually-hidden Previous
            button.carousel-control-next(type="button" data-bs-target="#carouselExampleInterval" data-bs-slide="next" ).d-flex.justify-content-end
                span.carousel-control-next-icon(aria-hidden="true" style="color:black;")
                span.visually-hidden Next
        
        .whatsappSupport 
            a(href='https://wa.me+905056609973?text=Merhaba%2C%20destek%20almak%20istiyorum' target='_blank')
                i.fa-brands.fa-whatsapp(style="color: #63E6BE;")

        .productsWrapper.mb-5.mt-5
            .row
                .col-6
                    .imageLeft 
                        a(href="").d-flex.justify-content-center 
                            img(src="https://img-tac-new.mncdn.com/Content/Images/Thumbs/0085724.jpeg", alt="" style="width:90%;") 
                .col-6
                    .imageLeft 
                        a(href="").d-flex.justify-content-center 
                            img(src="https://img-tac-new.mncdn.com/Content/Images/Thumbs/0085725.jpeg", alt="" style="width:90%;") 
       
        .containerBrands
            .container
                .row.homeProducts
                    each product in products
                        .col-lg-4.col-sm-6
                            a(href=`/productDetail/${product._id}`)
                                .card
                                    if Array.isArray(product.imageUrl) && product.imageUrl.length > 0
                                        img.card-img-top(src=product.imageUrl[0], alt="...")
                                    else if product.imageUrl && !Array.isArray(product.imageUrl)
                                        img.card-img-top(src=product.imageUrl, alt="...")
                                    else
                                        p Üzgünüz, ürün bulunamadı.
                                    .card-body
                                        h5.card-title #{product.name}
                                        - let productBrands = [];
                                        each brandId in product.brands
                                            - let productBrand = brands.find(brand => brand._id === brandId);
                                            - if (productBrand) productBrands.push(productBrand);
                                        each brand in productBrands
                                            span #{brand.name}
                                        if product.isOutOfStock
                                            p.card-text #{product.description} - STOKTA YOK
                                        else
                                           p.card-text 
                                                | #{product.description.slice(0, 60)}  
                                                if product.description.length > 60
                                                    | ...

