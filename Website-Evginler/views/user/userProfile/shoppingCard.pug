extends ../../layout/main-layout.pug

block content 
    h1.mt-5.mb-5 Sepetim 
    hr
    .container.mt-5 
        .row
        .col-12
                if cart.length === 0 
                    .container.shoppingCard
                        .emptyBasket
                            i.fa-solid.fa-cart-shopping
                            p.basketInfo Sepetinizde herhangi bir öğe bulunmamaktadır.
                        button(type="submit" class="startShopping") 
                            a(href="/").goShopping Alışverişe Başla 
        .row 
            .col-lg-6.col-sm-12 
                if cart.length > 0
                    table.table.table-striped
                        thead
                            tr
                                th(style="width: 20%;") Ürün Resmi
                                th(style="width: 20%;") Ürün Adı
                                th(style="width: 20%;") Adet
                                th(style="width: 20%;") Fiyat
                                th
                            tbody
                                each item in cart 
                                    tr.shoppingCardP-Detail
                                        td(style="vertical-align: middle;")
                                            img(src=`${item.imageUrl[0]}`, alt="Ürün Resmi", style="width: 100px; height: auto;")
                                        td(style="vertical-align: middle;") #{item.name}
                                        td(style="vertical-align: middle;")
                                            form(action="/updateQuantity", method="POST", onsubmit="updateQuantity(event); return false;")
                                                input(type="hidden", name="_csrf", value=csrfToken)
                                                input(type="hidden", name="productId", value=`${item.productId}`)
                                                input(type="number", name="quantity", value=item.quantity, min=1, max=10, onchange="this.form.submit()")
                                        td(style="vertical-align: middle;") #{item.price} ₺
                                        td(style="vertical-align: middle;")
                                            form(action="/deleteProduct", method="POST")
                                                input(type="hidden", name="_csrf", value=`${csrfToken}`)
                                                input(type="hidden", name="productId", value=`${item.productId}`)
                                                button(type="submit")
                                                    i.fa-solid.fa-xmark
            .col-6.shoppingCardTotalPrice
                if cart.length > 0
                    - var total = 0;
                    each item in cart  
                        - total += (item.price * item.quantity)
                    .subTotal 
                        span Ara Toplam
                        span : 
                        h5 #{total} ₺
                    .cargoPrice
                        - var shippingFee = total >= 500 ? 0 : 250;
                        span Kargo Ücreti
                        span : 
                        h5 #{shippingFee === 0 ? 'Ücretsiz' : shippingFee + ' ₺'}
                    .totalPrice 
                        -var fullPrice = (total + shippingFee)
                        span Toplam 
                        span : 
                        h5 #{fullPrice}
                    

                    form(action="/selectAddress", method="GET").paymentForm
                        button(type="submit").btn.saved_address_btn Alışverişi Tamamla 
                            i.fas.fa-arrow-right
